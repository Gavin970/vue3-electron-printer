    "typescript": "^5.4.2",
    "vite": "^7.0.6",
    "vite-plugin-electron": "^0.28.4",
    "vite-plugin-electron-renderer": "^0.14.5",
    "vue": "^3.4.21",
    "vue-tsc": "^2.0.6"
  },
  "dependencies": {
    "electron-log": "^5.4.0",
    "element-plus": "^2.9.11",
    "ws": "^8.18.2"
