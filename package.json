{
  "name": "newlion-print",
  "version": "1.0.0",
  "main": "dist-electron/main/index.js",
  "description": "NewlionPrintTool",
  "author": "Gavin",
  "license": "MIT",
  "private": true,
  "keywords": [
    "electron",
    "rollup",
    "vite",
    "vue3",
    "vue"
  ],
  "debug": {
